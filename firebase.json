{
  "hosting": {
    "site": "skills-hub",
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "!**/.claude-plugin", "!**/.claude-plugin/**"],
    "headers": [
      {
        "source": ".claude-plugin/**",
        "headers": [
          { "key": "Content-Type", "value": "application/json; charset=utf-8" }
        ]
      },
      {
        "source": "cowork/plugins/**/.claude-plugin/**",
        "headers": [
          { "key": "Content-Type", "value": "application/json; charset=utf-8" }
        ]
      },
      {
        "source": "**/*.skill",
        "headers": [
          { "key": "Content-Type", "value": "application/zip" },
          { "key": "Content-Disposition", "value": "attachment" }
        ]
      },
      {
        "source": "**/*.skill.b64.txt",
        "headers": [
          { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
        ]
      },
      {
        "source": "**/*.sig",
        "headers": [
          { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
        ]
      },
      {
        "source": "bootstrap/skills_hub_allowed_signers",
        "headers": [
          { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
        ]
      },
      {
        "source": "cowork/bootstrap/**",
        "headers": [
          { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
        ]
      },
      {
        "source": "**",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" },
          { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
        ]
      }
    ]
  }
}
