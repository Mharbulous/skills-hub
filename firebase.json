{
  "hosting": {
    "site": "skills-hub",
    "public": "public",
    "ignore": ["firebase.json", "**/.*"],
    "headers": [
      {
        "source": "**/*.skill",
        "headers": [
          { "key": "Content-Type", "value": "application/zip" },
          { "key": "Content-Disposition", "value": "attachment" }
        ]
      },
      {
        "source": "**",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" },
          { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
        ]
      }
    ]
  }
}
